---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import MockConversationTimeline from "../components/MockConversationTimeline";
import MockTeamsDashboard from "../components/MockTeamsDashboard";
import MockBranchView from "../components/MockBranchView";
import MockNetworkAccess from "../components/MockNetworkAccess";
import CopyButton from "../components/CopyButton";
import HeroScreenshot from "../components/HeroScreenshot";
---

<BaseLayout>
  <!-- ═══ HERO ═══ -->
  <HeroSection>
    <div class="grid items-center gap-12 lg:grid-cols-[0.8fr_1.5fr] lg:gap-12 lg:text-left">
      <!-- Left: Copy -->
      <div>
        <div class="fade-up">
          <div class="inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/5 px-3.5 py-1.5 text-[12px] font-medium text-blue-400/80 mb-8 readout">
            <span class="h-1.5 w-1.5 rounded-full bg-blue-400 pulse-live"></span>
            v0.3.1 — Desktop App + Network Access
          </div>
        </div>

        <h1 class="fade-up text-5xl font-bold tracking-tight sm:text-7xl lg:text-6xl xl:text-7xl leading-[0.9]" style="animation-delay: 80ms;">
          Your agents'<br />
          <span class="text-blue-400">control room</span>
        </h1>

        <p class="fade-up mt-6 max-w-2xl text-lg text-zinc-500 leading-relaxed sm:text-xl lg:text-lg xl:text-xl" style="animation-delay: 160ms;">
          See every tool call, track every token, rewind any decision. Cogpit is an open-source dashboard that turns opaque Claude Code sessions into a transparent, controllable experience.
        </p>

        <div class="fade-up mt-10 flex flex-wrap items-center justify-center gap-4 lg:justify-start" style="animation-delay: 240ms;">
          <a
            href="#get-started"
            class="group inline-flex items-center gap-2.5 rounded-xl bg-blue-500 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-blue-400 hover:shadow-[0_0_30px_rgba(59,130,246,0.3)]"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download
          </a>
          <a
            href="https://github.com/gentritbiba/cogpit"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2.5 rounded-xl border border-white/[0.08] bg-white/[0.03] px-6 py-3 text-sm font-medium text-zinc-300 transition-all hover:bg-white/[0.06] hover:border-white/[0.12]"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
            </svg>
            View Source
          </a>
          <a
            href="#demo"
            class="inline-flex items-center gap-2 text-sm text-zinc-600 transition-colors hover:text-zinc-400"
          >
            See it in action
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: Screenshot — bleeds to viewport edge -->
      <div class="fade-up lg:mr-[calc(-50vw+50%)] xl:mr-[calc(-50vw+50%+2rem)]" style="animation-delay: 320ms;">
        <HeroScreenshot client:load />
      </div>
    </div>
  </HeroSection>

  <!-- ═══ WHAT IS COGPIT — THREE PILLARS ═══ -->
  <section class="section-divide">
    <div class="mx-auto max-w-7xl px-6 py-24">
      <div class="mx-auto max-w-2xl text-center mb-16">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl" style="letter-spacing: -0.02em;">
          Three modes of operation
        </h2>
        <p class="mt-4 text-base text-zinc-500 leading-relaxed">
          Claude Code runs agents behind a terminal. Cogpit opens the black box.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        <!-- OBSERVE -->
        <div class="instrument-card rounded-2xl p-8 relative overflow-hidden group">
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-cyan-400/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="flex items-center gap-3 mb-5">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-cyan-500/10 border border-cyan-500/10">
              <svg class="h-5 w-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold" style="letter-spacing: -0.02em;">Observe</h3>
          </div>
          <p class="text-sm text-zinc-500 leading-relaxed mb-6">
            Watch agent sessions stream in real-time. Every tool call, file edit, thinking block, and sub-agent spawned — rendered as it happens.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="tag bg-cyan-500/5 text-cyan-400/70 border border-cyan-500/10">SSE Streaming</span>
            <span class="tag bg-cyan-500/5 text-cyan-400/70 border border-cyan-500/10">Live Diffs</span>
            <span class="tag bg-cyan-500/5 text-cyan-400/70 border border-cyan-500/10">Sub-Agents</span>
          </div>
        </div>

        <!-- UNDERSTAND -->
        <div class="instrument-card rounded-2xl p-8 relative overflow-hidden group">
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-blue-400/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="flex items-center gap-3 mb-5">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-500/10 border border-blue-500/10">
              <svg class="h-5 w-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold" style="letter-spacing: -0.02em;">Understand</h3>
          </div>
          <p class="text-sm text-zinc-500 leading-relaxed mb-6">
            Per-turn token costs, API rate limits, context window usage, and cache efficiency — all at a glance.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="tag bg-blue-500/5 text-blue-400/70 border border-blue-500/10">Token Charts</span>
            <span class="tag bg-blue-500/5 text-blue-400/70 border border-blue-500/10">Cost Tracking</span>
            <span class="tag bg-blue-500/5 text-blue-400/70 border border-blue-500/10">Rate Limits</span>
          </div>
        </div>

        <!-- CONTROL -->
        <div class="instrument-card rounded-2xl p-8 relative overflow-hidden group">
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-emerald-400/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="flex items-center gap-3 mb-5">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-500/10 border border-emerald-500/10">
              <svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold" style="letter-spacing: -0.02em;">Control</h3>
          </div>
          <p class="text-sm text-zinc-500 leading-relaxed mb-6">
            Send messages with voice or text, undo turns, branch conversations, manage permissions and MCP servers, and orchestrate multi-agent teams.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="tag bg-emerald-500/5 text-emerald-400/70 border border-emerald-500/10">Branching</span>
            <span class="tag bg-emerald-500/5 text-emerald-400/70 border border-emerald-500/10">Voice Input</span>
            <span class="tag bg-emerald-500/5 text-emerald-400/70 border border-emerald-500/10">Teams</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CONVERSATION TIMELINE DEMO ═══ -->
  <section id="demo" class="section-divide">
    <div class="mx-auto max-w-4xl px-6 py-24">
      <div class="text-center mb-12">
        <span class="tag bg-cyan-500/5 text-cyan-400/70 border border-cyan-500/10 mb-4">Core Feature</span>
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl" style="letter-spacing: -0.02em;">
          Conversation Timeline
        </h2>
        <p class="mt-4 text-base text-zinc-500 max-w-lg mx-auto">
          Every turn, tool call, edit diff, and agent thought — rendered in a structured, expandable view.
        </p>
      </div>
      <div class="mb-4 flex items-center gap-2.5 rounded-xl border border-blue-500/10 bg-blue-500/[0.03] px-4 py-3 text-[12px] text-blue-300/60 readout">
        <span class="h-1.5 w-1.5 rounded-full bg-blue-400 pulse-live shrink-0"></span>
        Components marked <strong class="text-blue-400/80">Interactive</strong> are live demos — click and explore.
      </div>
      <div class="relative rounded-2xl border border-white/[0.06] bg-card/50 p-4 sm:p-6 glow-blue">
        <span class="absolute -top-3 right-4 z-10 inline-flex items-center gap-1 rounded-full border border-blue-500/20 bg-blue-500/10 px-2.5 py-0.5 text-[10px] font-medium text-blue-400 backdrop-blur-sm readout">
          <span class="h-1.5 w-1.5 rounded-full bg-blue-400 pulse-live"></span>
          Interactive
        </span>
        <MockConversationTimeline client:load />
      </div>
    </div>
  </section>

  <!-- ═══ FEATURE GRID ═══ -->
  <section id="features" class="section-divide">
    <div class="mx-auto max-w-7xl px-6 py-24">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl" style="letter-spacing: -0.02em;">
          Everything at your fingertips
        </h2>
        <p class="mt-4 text-base text-zinc-500">
          Built for developers who want full visibility into what their AI agents are doing.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        <!-- Live Streaming -->
        <div class="instrument-card rounded-xl p-5">
          <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg text-blue-400 bg-blue-500/10 border border-blue-500/10">
            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold">Live Streaming</h3>
          <p class="mt-1.5 text-[12px] text-zinc-600 leading-relaxed">SSE-powered real-time updates. Watch thinking, tool calls, and edits stream in with auto-scrolling and live status indicators.</p>
        </div>
        <!-- Token Analytics -->
        <div class="instrument-card rounded-xl p-5">
          <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg text-cyan-400 bg-cyan-500/10 border border-cyan-500/10">
            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold">Token Analytics</h3>
          <p class="mt-1.5 text-[12px] text-zinc-600 leading-relaxed">Per-turn cost tracking with model-aware pricing, SVG charts, cache efficiency, context window usage, and API rate limit monitoring.</p>
        </div>
        <!-- Sub-Agent Tracking -->
        <div class="instrument-card rounded-xl p-5">
          <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg text-indigo-400 bg-indigo-500/10 border border-indigo-500/10">
            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold">Sub-Agent Viewer</h3>
          <p class="mt-1.5 text-[12px] text-zinc-600 leading-relaxed">Inline sub-agent and background agent panels with color-coded activity, per-agent tokens, and click-through to full sessions.</p>
        </div>
        <!-- Full-Text Search -->
        <div class="instrument-card rounded-xl p-5">
          <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg text-purple-400 bg-purple-500/10 border border-purple-500/10">
            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold">Full-Text Search</h3>
          <p class="mt-1.5 text-[12px] text-zinc-600 leading-relaxed">SQLite-indexed search across all sessions. Find any tool call, message, or code change instantly with highlighted matches.</p>
        </div>
        <!-- File Changes -->
        <div class="instrument-card rounded-xl p-5">
          <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg text-orange-400 bg-orange-500/10 border border-orange-500/10">
            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold">File Changes</h3>
          <p class="mt-1.5 text-[12px] text-zinc-600 leading-relaxed">Net-diff and per-edit views with LCS-based line diffs. Sub-agent attribution badges. Click to open in your editor.</p>
        </div>
        <!-- Voice & Images -->
        <div class="instrument-card rounded-xl p-5">
          <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg text-pink-400 bg-pink-500/10 border border-pink-500/10">
            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold">Voice & Images</h3>
          <p class="mt-1.5 text-[12px] text-zinc-600 leading-relaxed">Local Whisper WASM transcription, plus drag-and-drop image attachments with paste support and format conversion.</p>
        </div>
        <!-- Worktree Management -->
        <div class="instrument-card rounded-xl p-5">
          <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg text-emerald-400 bg-emerald-500/10 border border-emerald-500/10">
            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold">Worktree Management</h3>
          <p class="mt-1.5 text-[12px] text-zinc-600 leading-relaxed">Git worktrees with dirty/clean status, commits-ahead counts, linked sessions, PR creation, and bulk cleanup.</p>
        </div>
        <!-- Permissions & MCP -->
        <div class="instrument-card rounded-xl p-5">
          <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg text-rose-400 bg-rose-500/10 border border-rose-500/10">
            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold">Permissions & MCP</h3>
          <p class="mt-1.5 text-[12px] text-zinc-600 leading-relaxed">Configure permission modes (bypass, plan, delegate) and toggle MCP servers per-session from a searchable selector.</p>
        </div>
        <!-- Config Editor -->
        <div class="instrument-card rounded-xl p-5">
          <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg text-sky-400 bg-sky-500/10 border border-sky-500/10">
            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold">Config Editor</h3>
          <p class="mt-1.5 text-[12px] text-zinc-600 leading-relaxed">Browse and edit .claude/ skills, CLAUDE.md, and MCP configs directly in the dashboard with syntax highlighting.</p>
        </div>
        <!-- Process Monitor -->
        <div class="instrument-card rounded-xl p-5">
          <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg text-teal-400 bg-teal-500/10 border border-teal-500/10">
            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25z"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold">Process Monitor</h3>
          <p class="mt-1.5 text-[12px] text-zinc-600 leading-relaxed">Track all Claude CLI processes with PID, memory, CPU. Background task port detection and session linking.</p>
        </div>
        <!-- Parallel Sessions -->
        <div class="instrument-card rounded-xl p-5">
