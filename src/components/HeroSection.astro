---
import CockpitBackground from "./CockpitBackground.astro";

interface Props {
  backLink?: boolean;
}

const { backLink = false } = Astro.props;
---

<section class="relative overflow-x-clip overflow-y-visible scanline">
  <!-- Cockpit gear illustration -->
  <CockpitBackground />

  <!-- Layered gradients for depth -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_40%,oklch(0.25_0.06_264/0.3)_0%,transparent_70%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,oklch(0.13_0.008_265/0.92)_0%,oklch(0.13_0.008_265/0.5)_60%,transparent_100%)]"></div>

  <!-- Bottom fade to page bg -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-background to-transparent"></div>

  <!-- Content -->
  <div class={`relative z-10 mx-auto px-6 ${backLink ? "max-w-5xl pb-12 pt-20 sm:pt-24" : "max-w-7xl pb-16 pt-28 text-center sm:pt-32 lg:pt-28 lg:pb-20"}`}>
    {backLink && (
      <a href="/" class="inline-flex items-center gap-1.5 text-sm text-zinc-600 hover:text-blue-400 transition-colors mb-8">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to home
      </a>
    )}
    <slot />
  </div>
</section>
