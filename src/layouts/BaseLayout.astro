---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Cogpit — Your agents' control room",
  description = "Open-source control center for Claude Code. Real-time streaming, token analytics, conversation branching, multi-agent teams, and more.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/cogpit.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400..700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-background text-foreground grid-bg">
    <!-- Nav -->
    <nav class="fixed top-0 z-50 w-full border-b border-white/[0.04] bg-background/70 backdrop-blur-2xl">
      <div class="mx-auto flex h-14 max-w-7xl items-center justify-between px-6">
        <a href="/" class="group flex items-center gap-2.5">
          <img src="/cogpit.svg" alt="Cogpit" class="h-7 w-7" />
          <span class="text-lg font-semibold tracking-tight" style="font-family: Inter, sans-serif; letter-spacing: -0.02em;">Cogpit</span>
        </a>
        <div class="hidden items-center gap-7 text-[13px] text-zinc-500 md:flex">
          <a href="/#features" class="transition-colors hover:text-blue-400">Features</a>
          <a href="/#demo" class="transition-colors hover:text-blue-400">Demo</a>
          <a href="/teams" class="transition-colors hover:text-blue-400">Teams</a>
          <a href="/branching" class="transition-colors hover:text-blue-400">Branching</a>
          <a href="/network" class="transition-colors hover:text-blue-400">Network</a>
        </div>
        <div class="flex items-center gap-3">
          <a
            href="/#get-started"
            class="hidden sm:inline-flex items-center gap-2 rounded-lg bg-blue-500/10 border border-blue-500/20 px-3.5 py-1.5 text-[13px] font-medium text-blue-400 transition-all hover:bg-blue-500/15 hover:border-blue-500/30"
          >
            Get Started
          </a>
          <a
            href="https://github.com/gentritbiba/cogpit"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 rounded-lg border border-white/[0.06] bg-white/[0.03] px-3.5 py-1.5 text-[13px] font-medium text-zinc-400 transition-all hover:bg-white/[0.06] hover:text-zinc-200"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </nav>

    <!-- Main content -->
    <main class="pt-14">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="section-divide bg-background/80">
      <div class="mx-auto max-w-7xl px-6 py-16">
        <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
          <div class="flex flex-col gap-3">
            <div class="flex items-center gap-2.5">
              <img src="/cogpit.svg" alt="Cogpit" class="h-6 w-6" />
              <span class="text-base font-semibold" style="font-family: Inter, sans-serif; letter-spacing: -0.02em;">Cogpit</span>
            </div>
            <p class="text-sm text-zinc-600 max-w-xs">
              Open-source control center for Claude Code agent sessions.
            </p>
          </div>
          <div class="flex flex-wrap gap-x-12 gap-y-6 text-[13px]">
            <div class="flex flex-col gap-2.5">
              <span class="text-zinc-600 font-medium uppercase tracking-wider text-[11px]">Product</span>
              <a href="/#features" class="text-zinc-500 hover:text-blue-400 transition-colors">Features</a>
              <a href="/#demo" class="text-zinc-500 hover:text-blue-400 transition-colors">Demo</a>
              <a href="/#get-started" class="text-zinc-500 hover:text-blue-400 transition-colors">Get Started</a>
            </div>
            <div class="flex flex-col gap-2.5">
              <span class="text-zinc-600 font-medium uppercase tracking-wider text-[11px]">Deep Dives</span>
              <a href="/teams" class="text-zinc-500 hover:text-blue-400 transition-colors">Agent Teams</a>
              <a href="/branching" class="text-zinc-500 hover:text-blue-400 transition-colors">Branching</a>
              <a href="/network" class="text-zinc-500 hover:text-blue-400 transition-colors">Network Access</a>
            </div>
            <div class="flex flex-col gap-2.5">
              <span class="text-zinc-600 font-medium uppercase tracking-wider text-[11px]">Open Source</span>
              <a href="https://github.com/gentritbiba/cogpit" target="_blank" rel="noopener noreferrer" class="text-zinc-500 hover:text-blue-400 transition-colors">GitHub</a>
              <a href="https://github.com/gentritbiba/cogpit/releases" target="_blank" rel="noopener noreferrer" class="text-zinc-500 hover:text-blue-400 transition-colors">Releases</a>
              <span class="tag bg-white/[0.03] text-zinc-600 border border-white/[0.04]">MIT</span>
            </div>
          </div>
        </div>
        <div class="mt-12 pt-6 border-t border-white/[0.04] flex flex-col sm:flex-row items-center justify-between gap-3 text-[12px] text-zinc-700">
          <span>&copy; {new Date().getFullYear()} Gentrit Biba</span>
          <span class="readout">v0.3.1</span>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
